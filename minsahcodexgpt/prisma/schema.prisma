// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Minsah Beauty - Prisma Schema
// PostgreSQL Database for Dokploy Deployment

// ==========================================
// User & Authentication Models
// ==========================================

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  emailVerified   DateTime?
  passwordHash    String?
  firstName       String?
  lastName        String?
  phone           String?
  dateOfBirth     DateTime?
  gender          String?
  avatar          String?
  phoneVerified   Boolean    @default(false)
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  loyaltyPoints   Int        @default(0)
  referralCode    String?    @unique
  referredById    String?
  referredBy      User?      @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]     @relation("Referrals")

  newsletter          Boolean @default(true)
  smsNotifications    Boolean @default(false)
  promotions          Boolean @default(true)
  newProducts         Boolean @default(true)
  orderUpdates        Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  accounts            Account[]
  sessions            Session[]
  addresses           Address[]
  orders              Order[]
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]
  reviews             Review[]
  refreshTokens       RefreshToken[]
  customerBehavior    CustomerBehavior?
  searchHistory       SearchHistory?
  campaignAttribution CampaignAttribution?
  trackingDevice      TrackingDevice?
  returns             Return[]
  searchClicks        SearchClickEvent[]
  giftsSent           GiftRequest[]       @relation("GiftSender")
  giftsReceived       GiftRequest[]       @relation("GiftRecipient")

  @@index([email])
  @@index([referralCode])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([email])
  @@index([token])
}

// ==========================================
// Admin Models
// ==========================================

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  avatar       String?
  role         AdminRole  @default(STAFF)
  status       UserStatus @default(ACTIVE)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  refreshTokens      AdminRefreshToken[]
  shortlistItems     InventoryShortlist[]
  purchaseShortlist  PurchaseShortlist[]

  @@index([email])
}

model AdminRefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([token])
}

// ==========================================
// Address Model
// ==========================================

model Address {
  id         String      @id @default(cuid())
  userId     String
  type       AddressType @default(SHIPPING)
  isDefault  Boolean     @default(false)
  firstName  String
  lastName   String
  company    String?
  street1    String
  street2    String?
  city       String
  state      String
  postalCode String
  country    String      @default("Bangladesh")
  phone      String?
  pathaoCityId Int?
  pathaoZoneId Int?
  pathaoAreaId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// ==========================================
// Product Models
// ==========================================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([parentId])
}

model Brand {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  website     String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([slug])
}

model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?  @db.Text
  paymentTerms  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products       SupplierProduct[]
  purchaseOrders PurchaseOrder[]

  @@index([code])
  @@index([name])
  @@index([isActive])
}

model Product {
  id               String   @id @default(cuid())
  sku              String   @unique
  name             String
  slug             String   @unique
  description      String?  @db.Text
  shortDescription String?
  price            Decimal  @db.Decimal(10, 2)
  compareAtPrice   Decimal? @db.Decimal(10, 2)
  costPrice        Decimal? @db.Decimal(10, 2)

  // Inventory
  quantity          Int     @default(0)
  lowStockThreshold Int     @default(5)
  trackInventory    Boolean @default(true)
  allowBackorder    Boolean @default(false)

  // Physical attributes
  weight Decimal? @db.Decimal(10, 3)
  length Decimal? @db.Decimal(10, 2)
  width  Decimal? @db.Decimal(10, 2)
  height Decimal? @db.Decimal(10, 2)

  // Status
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  isNew      Boolean @default(false)

  // SEO
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  bengaliName        String?
  bengaliDescription String? @db.Text
  focusKeyword         String?
  secondaryKeywords    String[] @default([])
  bengaliFocusKeyword  String?
  bengaliSecondaryKeywords String[] @default([])
  ogDescription        String?
  ogTitle              String?
  ogImageUrl           String?
  canonicalUrl         String?

  // Full SEO rendering fields for product pages
  pageH1                    String?
  seoIntro                  String?  @db.Text
  faqSchemaNote             String?  @db.Text
  authenticityNote          String?  @db.Text
  ingredientVerificationStatus String?
  seoValidationChecklist    String[] @default([])

  // JSON-LD / technical SEO payloads
  structuredDataJsonLd      Json?
  productGroupJsonLd        Json?
  merchantListingJsonLd     Json?
  breadcrumbJsonLd          Json?
  sitemapIndexing           Json?
  variantUrlStrategy        Json?

  // Extended SEO & semantic search fields
  searchIntent         String?
  targetAudience       String?  @db.Text
  primaryConcern       String?
  keyBenefits          String[] @default([])
  buyingIntentKeywords String[] @default([])
  searchTags           String[] @default([])
  synonyms             String[] @default([])
  banglaSearchTerms    String[] @default([])
  reviewKeywords       String[] @default([])
  entities             String[] @default([])

  // Product page structured content
  descriptionSections  Json?
  productSpecs         Json?
  productAttributes    Json?
  shadeOptions         Json?
  variantPriceTable    Json?
  variantComparisonTable Json?
  internalLinks        Json?
  usageInstructions    String[] @default([])
  imageAltTexts        String[] @default([])
  faqSchemaReady       Boolean  @default(false)
  gender               String?

  // Beauty & Product Specs
  subcategory   String?
  skinType      String[]
  ingredients   String?   @db.Text
  shelfLife     String?
  expiryDate    DateTime?
  originCountry String?   @default("Bangladesh (Local)")

  // Shipping
  shippingWeight String?
  isFragile      Boolean @default(false)

  // Discount & Offers
  discountPercentage Decimal?  @db.Decimal(5, 2)
  salePrice          Decimal?  @db.Decimal(10, 2)
  offerStartDate     DateTime?
  offerEndDate       DateTime?
  flashSaleEligible  Boolean   @default(false)

  // Commerce Options
  returnEligible  Boolean @default(true)
  codAvailable    Boolean @default(true)
  preOrderOption  Boolean @default(false)
  barcode         String?
  relatedProducts String?

  // Structured Data
  condition     String?  @default("NEW")
  gtin          String?
  averageRating Decimal? @db.Decimal(3, 2)
  reviewCount   Int      @default(0)
  faqs          Json?

  // Tracking & product analytics counters
  viewCount           Int     @default(0)
  uniqueViewCount     Int     @default(0)
  addToCartCount      Int     @default(0)
  checkoutStartCount  Int     @default(0)
  orderCount          Int     @default(0)
  confirmedOrderCount Int     @default(0)
  deliveredOrderCount Int     @default(0)
  cancelledOrderCount Int     @default(0)
  returnedOrderCount  Int     @default(0)
  analyticsRevenue    Decimal @default(0) @db.Decimal(12, 2)

  // Relations
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  brandId    String?
  brand      Brand?    @relation(fields: [brandId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  images             ProductImage[]
  variants           ProductVariant[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  orderItems         OrderItem[]
  reviews            Review[]
  searchClicks       SearchClickEvent[]
  searchMetrics      SearchClickMetrics[]
  productDailyMetrics ProductDailyMetric[]
  productViewDedups  ProductViewDedup[]
  giftRequests       GiftRequest[]
  supplierLinks      SupplierProduct[]
  purchaseItems      PurchaseOrderItem[]
  shortlistItems     InventoryShortlist[]
  purchaseShortlist  PurchaseShortlist[]

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([brandId])
  @@index([deletedAt])
  @@index([isActive, isFeatured])
  @@index([isActive, deletedAt])
  @@index([canonicalUrl])
  @@index([viewCount])
  @@index([addToCartCount])
  @@index([orderCount])
  @@index([deliveredOrderCount])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  title     String?
  sortOrder Int     @default(0)
  isDefault Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  sku        String   @unique
  name       String
  price      Decimal? @db.Decimal(10, 2)
  quantity   Int      @default(0)
  attributes Json?
  image      String?

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
}

model ProductDailyMetric {
  id                  String   @id @default(cuid())
  productId           String
  metricDate          DateTime

  views               Int      @default(0)
  uniqueViews         Int      @default(0)
  addToCarts          Int      @default(0)
  checkoutStarts      Int      @default(0)
  orders              Int      @default(0)
  confirmedOrders     Int      @default(0)
  deliveredOrders     Int      @default(0)
  cancelledOrders     Int      @default(0)
  returnedOrders      Int      @default(0)

  revenue             Decimal  @default(0) @db.Decimal(12, 2)
  deliveredRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  estimatedProfit     Decimal? @db.Decimal(12, 2)

  addToCartRate       Decimal? @db.Decimal(7, 4)
  checkoutRate        Decimal? @db.Decimal(7, 4)
  purchaseRate        Decimal? @db.Decimal(7, 4)
  confirmationRate    Decimal? @db.Decimal(7, 4)
  deliveryRate        Decimal? @db.Decimal(7, 4)
  returnRate          Decimal? @db.Decimal(7, 4)

  grade               String?
  notes               String?  @db.Text

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, metricDate])
  @@index([metricDate])
  @@index([grade])
}

model ProductViewDedup {
  id             String   @id @default(cuid())
  productId      String
  visitorKeyHash String
  expiresAt      DateTime
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, visitorKeyHash])
  @@index([expiresAt])
  @@index([productId])
}

model SupplierProduct {
  id                     String    @id @default(cuid())
  supplierId             String
  productId              String
  supplierSku            String?
  lastPurchaseRate       Decimal?  @db.Decimal(10, 2)
  lowestPurchaseRate     Decimal?  @db.Decimal(10, 2)
  lowestPurchaseRateDate DateTime?
  lastPurchasedAt        DateTime?
  isPreferred            Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
  @@index([isPreferred])
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  orderNumber  String    @unique
  supplierId   String
  status       String    @default("DRAFT")
  notes        String?   @db.Text
  subtotal     Decimal   @default(0) @db.Decimal(10, 2)
  shippingCost Decimal   @default(0) @db.Decimal(10, 2)
  taxAmount    Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal   @default(0) @db.Decimal(10, 2)
  orderedAt    DateTime  @default(now())
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([orderedAt])
}

model PurchaseOrderItem {
  id               String    @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Int
  receivedQuantity Int       @default(0)
  unitCost         Decimal   @db.Decimal(10, 2)
  notes            String?   @db.Text
  receivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([receivedAt])
}

model InventoryShortlist {
  id        String    @id @default(cuid())
  adminId   String?
  productId String    @unique
  note      String?   @db.Text
  priority  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  admin   AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([priority])
}

// ==========================================
// Purchase Shortlist Model
// ==========================================

model PurchaseShortlist {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName String
  quantity    Int
  buyPrice    Decimal  @db.Decimal(10, 2)
  sellPrice   Decimal  @db.Decimal(10, 2)

  purchased   Boolean  @default(false)
  purchasedAt DateTime?
  priority    String   @default("NORMAL")
  notes       String?  @db.Text

  adminId     String?
  admin       AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
  @@index([adminId])
  @@index([purchased])
  @@index([priority])
}

// ==========================================
// Unlisted Products (Custom Products from Orders)
// ==========================================

model UnlistedProduct {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(0)
  costPrice   Decimal? @db.Decimal(10, 2)
  description String?  @db.Text
  image       String?
  usageCount  Int      @default(1)
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([sku])
  @@index([lastUsedAt])
}

// ==========================================
// Cart Models
// ==========================================

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  variantId String?
  quantity  Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@index([userId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ==========================================
// Order Models
// ==========================================

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?

  subtotal       Decimal @db.Decimal(10, 2)
  shippingCost   Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  addressId       String?
  shippingAddress Address? @relation(fields: [addressId], references: [id])
  shippingMethod  String?
  trackingNumber  String?

  steadfastConsignmentId String?
  steadfastTrackingCode  String?
  steadfastStatus        String?
  pathaoStatus           String?
  steadfastSentAt        DateTime?
  pathaoConsignmentId    String?
  pathaoTrackingCode     String?
  pathaoSentAt           DateTime?
  pathaoResponse         Json?

  couponCode     String?
  couponDiscount Decimal? @db.Decimal(10, 2)

  customerNote String?
  adminNote    String? @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  isGiftOrder  Boolean @default(false)
  giftToken    String?

  // Facebook / Meta CAPI data — save at checkout
  fbp                  String?
  fbc                  String?
  externalId           String?
  anonymousVisitorId   String?
  customerIp           String?
  customerUa           String?

  // GA4 / Measurement Protocol data
  gaClientId           String?
  gaSessionId          String?
  gaPurchaseSent       Boolean   @default(false)
  gaPurchaseSentAt     DateTime?
  gaPurchaseProcessingAt DateTime?
  gaRefundSent         Boolean   @default(false)
  gaRefundSentAt       DateTime?

  // Meta Purchase tracking / idempotency
  metaPurchaseSent     Boolean   @default(false)
  metaPurchaseSentAt   DateTime?
  metaPurchaseProcessingAt  DateTime?
  metaBrowserPurchaseClaimedAt DateTime?   // DB-level guard: signed browser purchase flow was authorized/claimed; not guaranteed Pixel delivery
  metaEventId          String?

  // UTM / Ad attribution
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  utmContent           String?
  campaignId           String?
  adsetId              String?
  adId                 String?
  placement            String?

  // Landing / creative / A-B test attribution
  firstLandingPath     String?
  firstLandingUrl      String?
  referrer             String?
  offerVersion         String?
  abVariant            String?

  // COD / payment / return timestamps
  phoneConfirmedAt     DateTime?
  paymentPaidAt        DateTime?
  returnedAt           DateTime?
  refundedAt           DateTime?

  // Test/internal order flag
  isTest               Boolean   @default(false)

  // Generic courier reconciliation
  courierName          String?
  courierConsignmentId String?
  courierStatus        String?
  courierDeliveredAt   DateTime?
  courierReturnedAt    DateTime?

  // Phone confirmation quality
  confirmationStatus   String?
  confirmationNote     String?   @db.Text
  confirmedByAdminId   String?

  // Tracking consent / privacy filters
  trackingConsent       String?  @default("unknown")
  nonEssentialTrackingAllowed Boolean @default(true)
  trackingFilteredReason String?

  // Tracking debug/version
  trackingSchemaVersion String?  @default("mb_tracking_v1")

  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]
  returns  Return[]
  notifications AdminNotification[]
  steadfastWebhookEvents SteadfastWebhookEvent[]
  pathaoWebhookEvents    PathaoWebhookEvent[]
  purchaseShortlist      PurchaseShortlist[]
  metaCapiFailures       MetaCapiFailure[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([steadfastConsignmentId])
  @@index([steadfastTrackingCode])
  @@index([pathaoConsignmentId])
  @@index([pathaoTrackingCode])
  @@index([isGiftOrder])
  @@index([giftToken])
  @@index([fbp])
  @@index([fbc])
  @@index([externalId])
  @@index([anonymousVisitorId])
  @@index([gaClientId])
  @@index([gaPurchaseSent])
  @@index([gaPurchaseProcessingAt])
  @@index([metaPurchaseSent])
  @@index([metaPurchaseProcessingAt])
  @@index([metaBrowserPurchaseClaimedAt])
  @@index([metaEventId])
  @@index([utmSource])
  @@index([campaignId])
  @@index([adsetId])
  @@index([adId])
  @@index([phoneConfirmedAt])
  @@index([paymentPaidAt])
  @@index([returnedAt])
  @@index([refundedAt])
  @@index([isTest])
  @@index([courierConsignmentId])
  @@index([confirmationStatus])
  @@index([trackingConsent])
  @@index([nonEssentialTrackingAllowed])
}

model PathaoWebhookEvent {
  id               String   @id @default(cuid())
  eventKey         String   @unique
  source           String   @default("pathao")
  eventType        String
  orderRef         String?
  consignmentId    String?
  signature        String?
  payload          Json
  orderId          String?
  processingStatus String   @default("RECEIVED")
  error            String?  @db.Text
  receivedAt       DateTime @default(now())
  processedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([eventType, receivedAt])
  @@index([orderRef])
  @@index([consignmentId])
  @@index([processingStatus, receivedAt])
}

model SteadfastWebhookEvent {
  id               String   @id @default(cuid())
  eventKey         String   @unique
  source           String   @default("steadfast")
  eventType        String
  invoice          String?
  consignmentId    String?
  trackingCode     String?
  status           String?
  trackingMessage  String?  @db.Text
  payload          Json
  orderId          String?
  processingStatus String   @default("RECEIVED")
  error            String?  @db.Text
  receivedAt       DateTime @default(now())
  processedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([eventType, receivedAt])
  @@index([invoice])
  @@index([consignmentId])
  @@index([trackingCode])
  @@index([processingStatus, receivedAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?
  name      String
  sku       String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  total     Decimal @db.Decimal(10, 2)

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant?  @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String

  // Existing checkout/payment fields
  method               String
  status               PaymentStatus @default(PENDING)
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("BDT")

  // Gateway idempotency / reconciliation
  gateway              String?
  transactionId        String?
  gatewayTransactionId String?       @unique
  rawStatus            String?
  gatewayResponse      Json?
  rawPayload           Json?
  verifiedAt           DateTime?

  // Safety checks
  signatureVerified    Boolean       @default(false)
  amountMatched        Boolean       @default(false)
  currencyMatched      Boolean       @default(false)

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([method])
  @@index([gateway])
  @@index([status])
  @@index([transactionId])
  @@index([verifiedAt])
}

// ==========================================
// Telegram Order Action Security
// ==========================================

model TelegramActionToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  action         String
  orderId        String
  telegramChatId String?
  messageId      String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([orderId])
  @@index([action])
  @@index([expiresAt])
  @@index([consumedAt])
}

model TelegramActionLog {
  id               String   @id @default(cuid())
  callbackQueryId  String?  @unique
  telegramUserId   String
  telegramUsername String?
  action           String
  orderId          String?
  status           String
  errorMessage     String?  @db.Text
  messageId        String?
  chatId           String?
  createdAt        DateTime @default(now())

  @@index([orderId])
  @@index([telegramUserId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
}

// ==========================================
// Tracking / CAPI Failure Log
// ==========================================

model MetaCapiFailure {
  id                String   @id @default(cuid())

  orderId           String?
  order             Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  eventName         String
  eventId           String?
  provider          String   @default("META")
  schemaVersion     String?  @default("mb_tracking_v1")

  statusCode        Int?
  errorCode         String?
  errorSubcode      String?
  errorMessage      String?  @db.Text

  retryCount        Int      @default(0)
  finalFailed       Boolean  @default(false)

  hasFbp            Boolean  @default(false)
  hasFbc            Boolean  @default(false)
  hasExternalId     Boolean  @default(false)
  hasEmailHash      Boolean  @default(false)
  hasPhoneHash      Boolean  @default(false)
  hasIp             Boolean  @default(false)
  hasUa             Boolean  @default(false)

  safePayload       Json?
  responsePayload   Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderId])
  @@index([eventName])
  @@index([eventId])
  @@index([provider])
  @@index([statusCode])
  @@index([errorCode])
  @@index([finalFailed])
  @@index([createdAt])
}

model TrackingHealthCheck {
  id                    String   @id @default(cuid())
  checkDate             DateTime

  ordersCreated         Int      @default(0)
  ordersConfirmed       Int      @default(0)
  metaPurchaseSent      Int      @default(0)
  gaPurchaseSent        Int      @default(0)
  capiFailureCount      Int      @default(0)

  status                String   @default("OK")
  notes                 String?  @db.Text
  details               Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([checkDate])
  @@index([status])
  @@index([createdAt])
}

// ==========================================
// Return Models
// ==========================================

model Return {
  id           String       @id @default(cuid())
  returnNumber String       @unique
  orderId      String
  userId       String
  reason       String
  status       ReturnStatus @default(PENDING)
  refundAmount Decimal      @db.Decimal(10, 2)
  adminNote    String?      @db.Text
  images       String[]
  requestDate  DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order      @relation(fields: [orderId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
  items ReturnItem[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnItem {
  id        String  @id @default(cuid())
  returnId  String
  name      String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  productId String?

  returnRequest Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

// ==========================================
// Review Model
// ==========================================

model Review {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  rating     Int
  title      String?
  comment    String? @db.Text
  isVerified Boolean @default(false)
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([isApproved])
}

// ==========================================
// Coupon Model
// ==========================================

model Coupon {
  id           String     @id @default(cuid())
  code         String     @unique
  description  String?
  type         CouponType @default(PERCENTAGE)
  value        Decimal    @db.Decimal(10, 2)
  minPurchase  Decimal?   @db.Decimal(10, 2)
  maxDiscount  Decimal?   @db.Decimal(10, 2)
  usageLimit   Int?
  usageCount   Int        @default(0)
  perUserLimit Int?
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ==========================================
// Customer Behavior Analytics
// ==========================================

model CustomerBehavior {
  id        String   @id @default(cuid())
  userId    String?  @unique
  deviceId  String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
}

// ==========================================
// Search History
// ==========================================

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?  @unique
  deviceId  String   @unique
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
}

// ==========================================
// Campaign Attribution
// ==========================================

model CampaignAttribution {
  id          String   @id @default(cuid())
  userId      String?  @unique
  deviceId    String   @unique
  firstTouch  Json?
  lastTouch   Json?
  touchpoints Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
}

// ==========================================
// Tracking Device
// ==========================================

model TrackingDevice {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  userId        String?  @unique
  firstTouchUtm Json?
  lastTouchUtm  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
}

// ==========================================
// Search Click Tracking
// ==========================================

model SearchClickEvent {
  id          String   @id @default(cuid())
  query       String
  productId   String
  position    Int
  resultCount Int
  filters     String?
  category    String?
  price       Float?
  score       Float?
  userId      String?
  deviceId    String?
  sessionId   String?
  clickedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([query])
  @@index([productId])
  @@index([userId])
  @@index([sessionId])
  @@index([clickedAt])
  @@map("search_click_events")
}

model SearchClickMetrics {
  id          String   @id @default(cuid())
  query       String
  productId   String
  avgPosition Float
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  resultCount Int?
  lastClicked DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([query, productId], name: "query_productId")
  @@index([query])
  @@index([productId])
  @@index([clicks])
  @@map("search_click_metrics")
}

// ==========================================
// Social Media Messages
// ==========================================

model SocialMessage {
  id             String   @id @default(cuid())
  platform       String
  type           String
  externalId     String?
  conversationId String?
  postId         String?
  senderId       String?
  senderName     String?
  senderAvatar   String?
  content        String   @db.Text
  rawPayload     Json?
  isIncoming     Boolean  @default(true)
  isRead         Boolean  @default(false)
  timestamp      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  attachments    SocialMessageAttachment[]

  @@index([platform])
  @@index([isRead])
  @@index([timestamp])
  @@unique([platform, externalId])
}

model SocialMessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  externalId   String?
  type         String
  mimeType     String?
  fileName     String?
  fileSize     Int?
  durationMs   Int?
  externalUrl  String?
  storageKey   String?
  storageUrl   String?
  thumbnailUrl String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  message SocialMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([type])
  @@unique([messageId, externalId])
}

// ==========================================
// Gift Request
// ==========================================

model GiftRequest {
  id               String     @id @default(cuid())
  token            String     @unique
  productId        String
  variantId        String?

  // Gift type
  giftType         String     @default("SEND_GIFT") // SEND_GIFT | GET_GIFT

  // Sender info
  senderName       String
  senderPhone      String?
  senderId         String?    // FK → User (social login verified)

  // Recipient / Payer info
  recipientName    String
  recipientId      String?    // FK → User (social login verified)

  // GET_GIFT — requester's address pre-saved
  requesterAddress Json?
  requesterPhone   String?

  // Shared
  message          String?    @db.Text
  status           GiftStatus @default(PENDING)
  viewedAt         DateTime?
  orderedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sender    User?   @relation("GiftSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient User?   @relation("GiftRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([productId])
  @@index([status])
  @@index([giftType])
  @@index([senderId])
  @@index([recipientId])
}

// ==========================================
// Admin Notifications
// ==========================================

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   @default("ORDER")
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  orderId   String?
  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@index([orderId])
}

// ==========================================
// Facebook Realtime Inbox
// ==========================================

model FbConversation {
  id            String      @id @default(cuid())
  threadId      String      @unique
  pageId        String
  customerPsid  String
  customerName  String?
  customerAvatar String?
  lastMessage   String?     @db.Text
  lastMessageAt DateTime?
  unreadCount   Int         @default(0)
  isReplied     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  messages      FbMessage[]

  @@index([pageId])
  @@index([lastMessageAt])
  @@index([isReplied])
}

model FbMessage {
  id             String         @id @default(cuid())
  fbMessageId    String         @unique
  conversationId String
  conversation   FbConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderType     FbSenderType
  text           String         @db.Text
  attachmentUrl  String?
  attachmentType FbAttachmentType?
  attachmentMimeType String?
  attachmentName String?
  rawPayload     Json?
  timestamp      DateTime
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([timestamp])
}

model FbWebhookAudit {
  id               String                    @id @default(cuid())
  source           String                    @default("facebook_messenger")
  pageId           String?
  signatureValid   Boolean                   @default(false)
  eventCount       Int                       @default(0)
  processedEvents  Int                       @default(0)
  failedEvents     Int                       @default(0)
  processingStatus FbWebhookProcessingStatus @default(RECEIVED)
  rawBody          String                    @db.Text
  payload          Json?
  error            String?                   @db.Text
  receivedAt       DateTime                  @default(now())
  processedAt      DateTime?

  @@index([processingStatus, receivedAt])
  @@index([pageId, receivedAt])
}

model FbOutboxMessage {
  id              String                @id
  pageId          String
  customerPsid    String
  agentId         String
  clientMessageId String?               @unique
  text            String                @db.Text
  attachmentUrl   String?
  attachmentType  FbAttachmentType?
  conversationId  String?
  localMessageId  String?
  fbMessageId     String?               @unique
  state           FbOutboxState         @default(PENDING)
  attempts        Int                   @default(0)
  lastError       String?               @db.Text
  lastAttemptAt   DateTime?
  queuedAt        DateTime              @default(now())
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  statusEvents    FbOutboxStatusEvent[]

  @@index([customerPsid, queuedAt])
  @@index([state, queuedAt])
  @@index([pageId, customerPsid])
}

model FbOutboxStatusEvent {
  id              String          @id @default(cuid())
  outboxMessageId String
  outboxMessage   FbOutboxMessage @relation(fields: [outboxMessageId], references: [id], onDelete: Cascade)
  state           FbOutboxState
  attempt         Int
  fbMessageId     String?
  conversationId  String?
  localMessageId  String?
  error           String?         @db.Text
  metadata        Json?
  createdAt       DateTime        @default(now())

  @@index([outboxMessageId, createdAt])
  @@index([fbMessageId])
}

model FbDeadLetterJob {
  id              String             @id @default(cuid())
  source          FbDeadLetterSource
  dedupeKey       String             @unique
  jobType         String
  pageId          String?
  threadId        String?
  fbMessageId     String?
  outboxMessageId String?
  status          FbDeadLetterStatus @default(OPEN)
  attempts        Int                @default(0)
  maxAttempts     Int
  failureCount    Int                @default(1)
  replayCount     Int                @default(0)
  lastError       String?            @db.Text
  payload         Json
  firstFailedAt   DateTime           @default(now())
  lastFailedAt    DateTime           @default(now())
  lastRequeuedAt  DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, lastFailedAt])
  @@index([source, status])
  @@index([pageId, threadId])
  @@index([fbMessageId])
  @@index([outboxMessageId])
}

// ==========================================
// Enums
// ==========================================

enum UserRole {
  CUSTOMER
  VIP
  PREMIUM
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum GiftStatus {
  PENDING
  VIEWED
  ORDERED
  EXPIRED
}

enum FbSenderType {
  CUSTOMER
  PAGE
}

enum FbAttachmentType {
  IMAGE
  VIDEO
  AUDIO
  FILE
}

enum FbOutboxState {
  PENDING
  QUEUED
  RETRYING
  SENT
  DELIVERED
  READ
  FAILED
}

enum FbWebhookProcessingStatus {
  RECEIVED
  PROCESSED
  PARTIAL_ERROR
  FAILED
}

enum FbDeadLetterSource {
  REPLAY_QUEUE
  MEDIA_RETRY
  OUTGOING_RETRY
}

enum FbDeadLetterStatus {
  OPEN
  REQUEUED
  RESOLVED
}
