w# Steadfast courier API
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
STEADFAST_DELIVERY_QUOTE_URL=

# Pathao courier API
# Production: https://api-hermes.pathao.com
# Sandbox: https://courier-api-sandbox.pathao.com
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=
PATHAO_CREATE_ORDER_ENDPOINT=/aladdin/api/v1/orders
PATHAO_WEBHOOK_CALLBACK_URL=https://minsahbeauty.cloud/api/webhooks/pathao
PATHAO_WEBHOOK_SECRET=
PATHAO_WEBHOOK_INTEGRATION_SECRET=f3992ecc-59da-4cbe-a049-a13da2018d51

# Steadfast webhook security (REQUIRED for /api/webhook/steadfast — set at least one)
# Any one match is enough (OR). Portal usually sends Authorization: Bearer <token>.
# STEADFAST_WEBHOOK_SECRET: raw token OR x-steadfast-webhook-secret header
STEADFAST_WEBHOOK_SECRET=
STEADFAST_WEBHOOK_AUTH_TOKEN=
# customer-key, x-api-key, or api-key header:
STEADFAST_WEBHOOK_CUSTOMER_KEY=
# Same Bearer token as portal; env may be "yourtoken" or "Bearer yourtoken"
STEADFAST_WEBHOOK_AUTHORIZATION=
# ===========================================
# Minsah Beauty - Environment Variables
# Domain: minsahbeauty.cloud
# ===========================================

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://minsahbeauty.cloud
NEXTAUTH_URL=https://minsahbeauty.cloud
NEXTAUTH_SECRET=generate-a-secure-random-string-min-32-chars

# JWT Authentication (REQUIRED)
# Used by both customer auth and admin auth.
# Admin cookies:
# - admin_access_token is signed with JWT_SECRET and uses JWT_ACCESS_EXPIRY.
# - admin_refresh_token is signed with JWT_REFRESH_SECRET and uses JWT_REFRESH_EXPIRY.
# Generate each secret as a different random 32+ character value.
JWT_SECRET=generate-another-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=generate-yet-another-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database - PostgreSQL (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://minsah:YOUR_DB_PASSWORD@your-postgres-host:5432/minsah_beauty
DIRECT_URL=postgresql://minsah:YOUR_DB_PASSWORD@your-postgres-host:5432/minsah_beauty

# Redis (REQUIRED for production)
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@your-redis-host:6379

# Elasticsearch (REQUIRED for search)
# Format: http://HOST:PORT  or  https://HOST:PORT
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTIC_PASSWORD=your-elasticsearch-password

# MinIO Object Storage (REQUIRED)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minsah_admin_2025
MINIO_SECRET_KEY=YourSuperSecurePassword123!
MINIO_BUCKET_NAME=minsah-beauty
MINIO_USE_SSL=false
NEXT_PUBLIC_MINIO_PUBLIC_URL=https://minio.minsahbeauty.cloud

# Logging
LOG_LEVEL=info

# AI Suggestions (Optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (Optional)
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# Facebook APIs (Optional)
FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_VERIFY_TOKEN=your-webhook-verify-token
FACEBOOK_GRAPH_API_VERSION=v22.0
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
FB_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FB_SYSTEM_USER_TOKEN=your-facebook-system-user-token
FB_PAGE_ID=your-facebook-page-id
FB_VERIFY_TOKEN=your-webhook-verify-token
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your-pixel-id
NEXT_PUBLIC_FB_PIXEL_ID=your-pixel-id
NEXT_PUBLIC_FB_PIXEL_ENABLED=true
FACEBOOK_CONVERSION_API_TOKEN=your-conversion-api-token

# Instagram (Optional)
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# WhatsApp Business API (Optional)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# YouTube (Optional)
YOUTUBE_ACCESS_TOKEN=your-youtube-access-token

# Payment Gateways

# bKash (Optional)
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# Nagad (Optional)
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_NUMBER=your-nagad-merchant-number
NAGAD_PUBLIC_KEY=your-nagad-public-key
NAGAD_PRIVATE_KEY=your-nagad-private-key

# Rocket (Optional)
ROCKET_MERCHANT_ID=your-rocket-merchant-id
ROCKET_MERCHANT_SECRET=your-rocket-merchant-secret

# SSLCommerz (Optional)
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_IS_SANDBOX=false

# Analytics & Tracking (Optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=your-conversion-label
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your-tiktok-pixel-id
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=your-snapchat-pixel-id
NEXT_PUBLIC_PINTEREST_TAG_ID=your-pinterest-tag-id
NEXT_PUBLIC_TWITTER_PIXEL_ID=your-twitter-pixel-id
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=your-linkedin-partner-id
NEXT_PUBLIC_REDDIT_PIXEL_ID=your-reddit-pixel-id
NEXT_PUBLIC_MICROSOFT_UET_TAG_ID=your-microsoft-tag-id
NEXT_PUBLIC_HOTJAR_SITE_ID=your-hotjar-site-id
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# CORS Configuration
ALLOWED_ORIGINS=https://minsahbeauty.cloud,https://www.minsahbeauty.cloud

# Email (Optional - for password reset, order notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@minsahbeauty.cloud

# Admin Configuration
# Set this for the initial admin user during first deployment
INITIAL_ADMIN_EMAIL=admin@minsahbeauty.cloud
INITIAL_ADMIN_PASSWORD=ChangeThisImmediately123!

# Realtime inbox service
NEXT_PUBLIC_REALTIME_WS_URL=wss://realtime.minsahbeauty.cloud/ws
NEXT_PUBLIC_WS_AUTH_SECRET=minimum_32_characters_random_string_here
REALTIME_SERVICE_INTERNAL_URL=http://realtime-service:3001
REPLY_API_SECRET=minimum_32_characters_random_string_here
WS_AUTH_SECRET=minimum_32_characters_random_string_here
